# ---- Required ----

# Anthropic API key — powers the code-vs-docs analysis.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Firecrawl API key — crawls the documentation site to Markdown.
# Free tier gives 500 credits/month: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# ---- Optional ----

# GitHub token — raises the public API rate limit from 60/hr to 5,000/hr.
# A classic token with no scopes (public repos only) is plenty.
# GITHUB_TOKEN=ghp_...

# Vercel Blob — durable storage so /report/<id> links are shareable.
# Auto-provisioned on Vercel when you add a Blob store. Without it, reports are
# written to a local .reports/ directory (fine for local dev).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Override the analysis model (default: claude-opus-4-8).
# ANALYSIS_MODEL=claude-sonnet-4-6

# Set to "false" to skip the breadth crawl and only scrape the primary docs
# page (saves Firecrawl credits).
# DRIFT_CRAWL=false

# Public base URL, used for absolute share/OG links.
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
